APP_NAME=StarterCore
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# URL pública de la API (ajusta host/puerto si usas otro servidor)
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# Demo: en local, por defecto el DemoUserSeeder vuelve a fijar contraseñas conocidas al seedear.
# Pon false si no quieres sobrescribir hashes de usuarios demo existentes.
# DEMO_RESET_DEMO_PASSWORDS=true

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# CORS: debe incluir el origen del front (Vite suele ser :5173)
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With,Accept,Origin
CORS_EXPOSED_HEADERS=
CORS_MAX_AGE=600
CORS_SUPPORTS_CREDENTIALS=false

# Trial: días de prueba para empresas creadas desde Plataforma (PlatformTenantProvisioningService)
TENANT_DEFAULT_TRIAL_DAYS=14

# Plataforma (alta fiscal): en desarrollo permite RFC repetido (no bloquea creación).
ALLOW_DUPLICATE_RFC=true

METRICS_ENABLED=true
METRICS_PREFIX=metrics
METRICS_COUNTER_TTL_SECONDS=604800
# Opcional: store dedicado para métricas (por defecto usa cache.default)
METRICS_STORE=

# Infra edge / reverse proxy
# TRUSTED_PROXIES=10.0.0.0/8,127.0.0.1
# TRUSTED_HOSTS=^api\\.example\\.com$,^staging-api\\.example\\.com$

# API auth (Sanctum + sesiones)
AUTH_ACCESS_TTL_MINUTES=60
AUTH_REFRESH_TTL_DAYS=14

# --- Base de datos ---
# Por defecto: SQLite (rápido para desarrollo y tests). Sin DB_DATABASE, Laravel usa database/database.sqlite
DB_CONNECTION=sqlite
# DB_DATABASE=/ruta/absoluta/otro.sqlite

# MySQL / MariaDB (equipos que usan BD compartida o despliegue típico)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=starter_core
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Sanctum (API bearer-only). En producción conviene definir prefijo para secret scanning.
SANCTUM_TOKEN_PREFIX=

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
