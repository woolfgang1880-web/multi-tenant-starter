# ===========================================
# starter-core API (Express) — variables de entorno
# Copiar a .env y ajustar valores.
# ===========================================

# Entorno (development | production)
NODE_ENV=development

# Puerto del servidor
PORT=8000

# Secretos JWT — OBLIGATORIOS en producción
# Generar con: openssl rand -hex 32
ACCESS_TOKEN_SECRET=dev-access-token-secret-change-me
REFRESH_TOKEN_SECRET=dev-refresh-token-secret-change-me

# Longitud mínima de contraseña
PASSWORD_MIN_LENGTH=8
