# URL base de la API versionada en starter-core (sin barra final).
# Usa 127.0.0.1 en lugar de "localhost" en Windows/Vite para evitar IPv4/IPv6 inconsistentes.
# Debe coincidir con el host donde corre `php artisan serve` (p. ej. :8000).
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1

# La UI técnica (diagnóstico JSON, modal en plataforma, tabla/atajos demo en login) solo existe
# cuando corres `npm run dev`. En build de producción no se muestra (import.meta.env.DEV === false).

# Alinea CORS en starter-core (.env) con el origen del front, p. ej.:
# CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Email de soporte (opcional): en la pantalla de suscripción expirada muestra el enlace "Contactar soporte" (mailto).
# VITE_SUPPORT_EMAIL=soporte@ejemplo.com

# JWT opcional solo para desarrollo (no subas tokens reales al repo)
# VITE_API_TOKEN=
